<?xml version="1.0"?>
<robot name="rover_ackermann">

  <!-- ==================== LINKS ==================== -->

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <origin xyz="0.25 0 -0.12" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ackermann_rover_bringup/urdf/meshes/rover_ackermann_base.dae"/>
      </geometry>
    </visual>
  </link>

  <!-- Wheels -->
  <link name="wheel_rear_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ackermann_rover_bringup/urdf/meshes/rover_ackermann_wheel.dae"/>
      </geometry>
    </visual>
  </link>

  <link name="wheel_rear_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ackermann_rover_bringup/urdf/meshes/rover_ackermann_wheel.dae"/>
      </geometry>
    </visual>
  </link>

  <link name="wheel_front_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ackermann_rover_bringup/urdf/meshes/rover_ackermann_wheel.dae"/>
      </geometry>
    </visual>
  </link>

  <link name="wheel_front_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ackermann_rover_bringup/urdf/meshes/rover_ackermann_wheel.dae"/>
      </geometry>
    </visual>
  </link>

  <!-- Sensors -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <link name="laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ackermann_rover_bringup/urdf/meshes/lidar_2d_v2.dae"/>
      </geometry>
    </visual>
  </link>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <link name="sonar_front_link">
    <visual>
      <geometry><box size="0.01 0.02 0.01"/></geometry>
      <material name="green"><color rgba="0 1 0 0"/></material>
    </visual>
  </link>

  <link name="sonar_rear_link">
    <visual>
      <geometry><box size="0.01 0.02 0.01"/></geometry>
      <material name="green"><color rgba="0 1 0 0"/></material>
    </visual>
  </link>

  <link name="gps_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.01"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- ==================== JOINTS ==================== -->

  <!-- Wheel Joints (Fixed for Visualization) -->
  <joint name="wheel_rear_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_rear_left_link"/>
    <origin xyz="0 0.3 -0.1" rpy="-1.5707 0 0"/>
  </joint>

  <joint name="wheel_rear_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_rear_right_link"/>
    <origin xyz="0 -0.3 -0.1" rpy="-1.5707 0 0"/>
  </joint>

  <joint name="wheel_front_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0.5 0.3 -0.1" rpy="-1.5707 0 0"/>
  </joint>

  <joint name="wheel_front_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0.5 -0.3 -0.1" rpy="-1.5707 0 0"/>
  </joint>

  <!-- Sensor Joints -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.55 0 0.2" rpy="0 0 0"/>
  </joint>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.55 0 0.4" rpy="0 0 0"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="sonar_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_front_link"/>
    <origin xyz="0.68 0 0.0" rpy="0 0 0"/>
  </joint>

  <joint name="sonar_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sonar_rear_link"/>
    <origin xyz="-0.18 0 0.0" rpy="0 0 3.14159"/>
  </joint>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>

</robot>
